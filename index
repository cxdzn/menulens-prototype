<!-- ══ RIGHT COLUMN — CX ANALYTICS ══ -->
<div class="col-right" id="colRight">
  <div class="analytics-title">CX Analytics</div>
  <div style="font-size:0.73rem;color:var(--text-3);margin-top:-0.875rem">Live accessibility impact · 30-day rolling</div>
  <div class="kpi-grid">
    <div class="kpi-card"><div class="kpi-label">Simplifications</div><div class="kpi-value" id="kpi1">…</div><div class="kpi-delta delta-up">↑ 23% vs last month</div></div>
